# ────────────────────────────────────────────────────────────────────
# MLB HR Parlay — environment variables
# Copy to `.env.local` for local dev. Never commit secrets.
# ────────────────────────────────────────────────────────────────────

# ─── Public site config ─────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="MLB HR Parlay"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── MLB Stats API (free / no key required) ─────────────────────────
# Used as the base for schedule, lineups, players, boxscores.
# Documented at https://statsapi.mlb.com — no auth, but be polite with rate.
MLB_STATS_API_BASE="https://statsapi.mlb.com/api/v1"

# ─── Baseball Savant / Statcast (no key, scraped CSV endpoints) ─────
# Savant CSV search endpoint; we hit it server-side and cache aggressively.
SAVANT_BASE="https://baseballsavant.mlb.com"

# ─── FanGraphs (no official key; we use their public leaderboards JSON) ─
# Treat as best-effort; expect schema drift. Always validate with zod.
FANGRAPHS_BASE="https://www.fangraphs.com"

# ─── Open-Meteo (free weather API, no key) ──────────────────────────
OPEN_METEO_BASE="https://api.open-meteo.com/v1"

# ─── Caching / runtime ──────────────────────────────────────────────
# TTL for cached fetches in seconds. Daily data → long; live data → short.
CACHE_TTL_SCHEDULE_S=3600       # 1h — schedule rarely changes intra-day
CACHE_TTL_LINEUPS_S=300         # 5m — confirmed lineups update near gametime
CACHE_TTL_STATCAST_S=21600      # 6h — Statcast updates overnight
CACHE_TTL_PARK_FACTORS_S=604800 # 7d — park factors are seasonal
CACHE_TTL_WEATHER_S=1800        # 30m — refresh as gametime approaches

# ─── Production cache: Upstash Redis (HTTP/REST) ────────────────────
# Required in production on Vercel — the in-memory cache does NOT persist
# across serverless invocations, so without this you re-hit the upstream
# APIs on every request (and will get rate-limited).
#
# Easiest setup: Vercel dashboard → Storage → Upstash Redis. The integration
# injects both vars automatically into your deployment. For local dev, copy
# them from the Upstash console. Leave blank to use the in-memory fallback.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ─── Production persistence: Postgres (parlay history) ──────────────
# Required for durable history/tracking. Vercel dashboard → Storage →
# Postgres (or Neon) injects POSTGRES_URL automatically. If unset, history
# uses a non-durable in-memory store that resets on every cold start.
POSTGRES_URL=""

# ─── Cron auth ──────────────────────────────────────────────────────
# Shared secret protecting /api/cron/* (record + settle). Set this in Vercel
# and it will be sent automatically as a Bearer token to scheduled cron runs.
# Generate with: openssl rand -hex 32
CRON_SECRET=""

# ─── Logging ────────────────────────────────────────────────────────
LOG_LEVEL="info"   # debug | info | warn | error
